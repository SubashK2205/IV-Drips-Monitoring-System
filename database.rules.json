{
  "rules": {
    "devices": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },
    "alerts": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "maintenance": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    },
    "admins": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || root.child('admins').child(auth.uid).child('role').val() === 'admin')"
      }
    },
    "patients": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('admins').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
